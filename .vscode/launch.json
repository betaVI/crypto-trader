    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: TradingBot",
            "type": "python",
            "request": "launch",
            "env": { "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/bots"},
            "cwd": "${workspaceFolder}/bots",
            "program": "tradingbot.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: DataBot",
            "type": "python",
            "request": "launch",
            "env": { "PYTHONPATH": "${workspaceFolder}"},
            "cwd": "${workspaceFolder}/bots",
            "program": "databot.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Site",
            "type": "python",
            "request": "launch",
            "env": { "PYTHONPATH": "${workspaceFolder}"},
            "cwd": "${workspaceFolder}/site",
            "program": "app.py",
            "console": "integratedTerminal"
        },
    ],
    "compounds": [
        {
            "name": "Site/DataBot",
            "configurations": ["Python: Site", "Python: DataBot"]
        }
    ]
}